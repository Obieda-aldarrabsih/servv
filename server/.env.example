# انسخ إلى .env ولا ترفع .env إلى Git
# خيار 1: قاعدة واحدة فقط
# MONGODB_URI=mongodb+srv://USER:PASS@cluster0.xxxxx.mongodb.net/yasmeen?retryWrites=true&w=majority
#
# خيار 2: عدة قواعد على نفس السيرفر (الأفضل للتوسع)
# DEFAULT_APP_KEY=yasmeen
# MONGODB_URI_MAP={"yasmeen":"mongodb+srv://.../yasmeen?retryWrites=true&w=majority","client2":"mongodb+srv://.../client2?retryWrites=true&w=majority"}
# كلمة مرور صفحة إدارة تغيير قاعدة البيانات (مطلوبة لصفحة db-config.html)
# ADMIN_CONFIG_PASSWORD=StrongPasswordHere
PORT=3000
